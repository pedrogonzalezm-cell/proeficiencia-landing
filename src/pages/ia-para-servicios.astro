---
import SegmentLayout from '../layouts/SegmentLayout.astro';
import ScrollReveal from '../components/ui/ScrollReveal.astro';

const waUrl = 'https://wa.me/56964285737?text=Hola%2C%20me%20interesa%20la%20evaluaci%C3%B3n%20para%20mi%20negocio%20de%20servicio';

const quickWins = [
  {
    title: 'Chatbot para reservas por WhatsApp',
    problem: 'Pierdes clientes porque no respondes a tiempo o fuera de horario. Cada reserva manual toma 5–10 minutos.',
    solution: 'Instalamos un chatbot (Tidio o ManyChat) conectado a tu WhatsApp que recibe reservas, confirma disponibilidad y envía confirmación automática — las 24 horas.',
    saving: '3–5 horas semanales en gestión de agenda',
    tool: 'Tidio / ManyChat',
  },
  {
    title: 'Recordatorios automáticos de citas',
    problem: 'Los no-shows te cuestan entre el 10% y el 25% de tu facturación mensual. Llamar para confirmar citas es tedioso.',
    solution: 'Configuramos una automatización (Make + WhatsApp) que envía recordatorio 24 horas antes de cada cita y pide confirmación. Si el cliente cancela, te avisa al instante.',
    saving: 'Reduce no-shows en un 40–60%',
    tool: 'Make + WhatsApp Business',
  },
  {
    title: 'Seguimiento post-servicio para fidelizar',
    problem: 'La mayoría de los clientes no vuelve — no porque no les gustó, sino porque nadie los invitó. La fidelización manual es imposible de escalar.',
    solution: 'Automatizamos un mensaje de seguimiento 3 días después del servicio (Make + Gmail/WhatsApp) con encuesta de satisfacción y oferta de próxima cita.',
    saving: 'Aumenta recompras en 20–35%',
    tool: 'Make + Gmail',
  },
];

const faqs = [
  {
    question: '¿Funciona para negocios pequeños con 1 a 5 personas?',
    answer: 'Sí, es exactamente para ese tamaño. Nuestras automatizaciones están diseñadas para negocios donde el dueño hace de todo: atiende, cobra y agenda. Las herramientas que instalamos cuestan entre $30 y $80 USD al mes — menos que contratar una persona para que haga lo mismo.',
  },
  {
    question: '¿Puedo automatizar las reservas que llegan por WhatsApp?',
    answer: 'Sí. Es uno de los Quick Wins más solicitados. Instalamos un chatbot conectado a tu número de WhatsApp Business que responde consultas, verifica disponibilidad en tu agenda y confirma la reserva — sin que tengas que hacer nada. Funciona 24/7.',
  },
  {
    question: '¿Cuánto cuesta implementar IA en una clínica dental o salón de belleza?',
    answer: 'El diagnóstico completo con reporte de Quick Wins cuesta $199 USD. Si agregas implementación (nosotros instalamos todo), el plan es $497 USD. Las herramientas que dejamos instaladas cuestan entre $30 y $80 USD al mes. El ahorro típico en el primer mes supera los $1.500 USD en horas y no-shows recuperados.',
  },
  {
    question: '¿Necesito tener una página web para automatizar con IA?',
    answer: 'No. La mayoría de las automatizaciones para negocios de servicio funcionan directamente sobre WhatsApp, Gmail y tu agenda (Google Calendar o similar). No necesitas página web, sistema de gestión, ni conocimientos técnicos. Nosotros configuramos todo.',
  },
];
---

<SegmentLayout
  title="Automatización con IA para negocios de servicio en Chile | ProeficiencIA"
  description="Automatiza reservas, reduce no-shows y fideliza clientes con IA. Diagnóstico para lavanderías, salones, clínicas, hoteles y servicios en Chile desde $199 USD."
>
  <!-- Hero -->
  <section class="bg-canvas py-20 md:py-28 px-6">
    <div class="max-w-[780px] mx-auto text-center">
      <ScrollReveal>
        <p class="text-primary font-semibold text-sm uppercase tracking-widest mb-4">Para negocios de servicio en Chile</p>
        <h1 class="font-display text-display-md md:text-display-lg font-semibold tracking-tight text-ink leading-tight mb-6" style="letter-spacing: -0.02em;">
          Automatización con IA para negocios de servicio en Chile
        </h1>
        <p class="text-body-md text-muted leading-relaxed mb-8 max-w-[600px] mx-auto">
          Lavanderías, salones de belleza, clínicas dentales, hoteles, panaderías. Si tu negocio depende de agenda, citas y clientes que vuelven — la IA puede recuperarte entre 5 y 10 horas semanales desde el primer mes.
        </p>
        <a
          href={waUrl}
          target="_blank"
          rel="noopener"
          class="inline-block bg-primary text-on-primary font-semibold px-8 py-4 rounded-md hover:bg-primary-active transition-all hover:scale-[1.02] text-body-sm"
        >
          Solicitar diagnóstico gratuito →
        </a>
        <p class="text-xs text-muted mt-3">Diagnóstico desde $199 USD · Implementación incluida en plan Pro</p>
      </ScrollReveal>
    </div>
  </section>

  <!-- Pain -->
  <section class="bg-surface-soft py-16 md:py-20 px-6">
    <div class="max-w-[700px] mx-auto">
      <ScrollReveal>
        <h2 class="font-display text-display-sm font-semibold tracking-tight text-ink mb-6" style="letter-spacing: -0.01em;">
          ¿Cuántas horas pierde tu negocio en tareas que se podrían automatizar?
        </h2>
        <div class="space-y-4 text-body-sm text-muted leading-relaxed">
          <p>
            Un negocio de servicio típico pierde entre 8 y 15 horas semanales en tareas administrativas repetitivas: confirmar citas por WhatsApp, llamar para recordar reservas, responder las mismas preguntas una y otra vez, y hacer seguimiento manual a clientes que no volvieron.
          </p>
          <p>
            El problema no es falta de voluntad — es que esas tareas son necesarias pero no generan ingresos. Cada minuto que el dueño pasa confirmando una reserva es un minuto que no está atendiendo clientes, mejorando el servicio o cerrando nuevas ventas.
          </p>
          <p>
            La IA no reemplaza el trato humano que hace especial a tu negocio. Automatiza la parte administrativa para que tú puedas enfocarte en lo que importa.
          </p>
        </div>
      </ScrollReveal>

      <ScrollReveal delay={100}>
        <div class="mt-8 grid grid-cols-3 gap-4 text-center">
          {[
            { stat: '8–15 hrs', label: 'perdidas por semana en admin' },
            { stat: '10–25%', label: 'de ingresos por no-shows' },
            { stat: '60%', label: 'de clientes no vuelven sin seguimiento' },
          ].map((item) => (
            <div class="bg-canvas rounded-lg p-4 border border-hairline">
              <div class="font-display text-display-sm font-semibold text-primary">{item.stat}</div>
              <div class="text-xs text-muted mt-1">{item.label}</div>
            </div>
          ))}
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Quick Wins -->
  <section class="bg-canvas py-16 md:py-24 px-6">
    <div class="max-w-[900px] mx-auto">
      <ScrollReveal>
        <h2 class="font-display text-display-sm font-semibold tracking-tight text-ink text-center mb-3" style="letter-spacing: -0.01em;">
          Lo que automatizamos para negocios de servicio
        </h2>
        <p class="text-body-sm text-muted text-center mb-12 max-w-[520px] mx-auto">
          Tres soluciones concretas, con herramientas específicas y ROI proyectado. No teoría — implementación real.
        </p>
      </ScrollReveal>

      <div class="space-y-6">
        {quickWins.map((qw, i) => (
          <ScrollReveal delay={i * 80}>
            <div class="bg-surface-soft rounded-xl p-6 md:p-8 border border-hairline">
              <div class="flex items-start gap-4">
                <div class="w-8 h-8 rounded-full bg-primary/10 text-primary font-semibold text-sm flex items-center justify-center flex-shrink-0 mt-0.5">
                  {i + 1}
                </div>
                <div class="flex-1">
                  <h3 class="font-display text-title-lg font-semibold text-ink mb-3">{qw.title}</h3>
                  <p class="text-body-sm text-muted mb-3"><strong class="text-body-strong">El problema:</strong> {qw.problem}</p>
                  <p class="text-body-sm text-muted mb-4"><strong class="text-body-strong">La solución:</strong> {qw.solution}</p>
                  <div class="flex flex-wrap gap-3">
                    <span class="inline-flex items-center gap-1.5 text-xs font-medium text-accent-teal bg-accent-teal/10 px-3 py-1.5 rounded-full">
                      ✓ {qw.saving}
                    </span>
                    <span class="inline-flex items-center gap-1.5 text-xs text-muted bg-surface-card px-3 py-1.5 rounded-full">
                      Herramienta: {qw.tool}
                    </span>
                  </div>
                </div>
              </div>
            </div>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="bg-surface-soft py-16 md:py-20 px-6">
    <div class="max-w-[700px] mx-auto text-center">
      <ScrollReveal>
        <h2 class="font-display text-display-sm font-semibold tracking-tight text-ink mb-10" style="letter-spacing: -0.01em;">
          ¿Cómo funciona el diagnóstico?
        </h2>
      </ScrollReveal>
      <div class="grid md:grid-cols-3 gap-6 text-left">
        {[
          { step: '1', title: 'Diagnóstico (60 min)', desc: 'Sesión por videollamada donde revisamos tus procesos actuales, herramientas y tareas repetitivas. Identificamos exactamente dónde la IA te ahorra más.' },
          { step: '2', title: 'Reporte con Quick Wins', desc: 'Recibes un documento con 3 automatizaciones priorizadas por impacto, las herramientas específicas, el costo mensual y el ROI proyectado para tu negocio.' },
          { step: '3', title: 'Implementación en 4 días', desc: 'Si optas por el plan Pro, nuestro equipo instala y configura todo. El día 5 ya estás ahorrando horas. Te capacitamos en el uso.' },
        ].map((item) => (
          <ScrollReveal delay={parseInt(item.step) * 80}>
            <div class="bg-canvas rounded-xl p-6 border border-hairline">
              <div class="font-display text-display-sm font-bold text-primary mb-3">{item.step}</div>
              <h3 class="font-body font-semibold text-ink text-body-md mb-2">{item.title}</h3>
              <p class="text-body-sm text-muted leading-relaxed">{item.desc}</p>
            </div>
          </ScrollReveal>
        ))}
      </div>
      <ScrollReveal delay={300}>
        <div class="mt-10">
          <a
            href={waUrl}
            target="_blank"
            rel="noopener"
            class="inline-block bg-primary text-on-primary font-semibold px-8 py-4 rounded-md hover:bg-primary-active transition-all hover:scale-[1.02] text-body-sm"
          >
            Solicitar diagnóstico →
          </a>
          <p class="text-xs text-muted mt-3">$199 USD · Solo diagnóstico &nbsp;|&nbsp; $497 USD · Con implementación incluida</p>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-canvas py-16 md:py-20 px-6">
    <div class="max-w-[700px] mx-auto">
      <ScrollReveal>
        <h2 class="font-display text-display-sm font-semibold tracking-tight text-ink text-center mb-10" style="letter-spacing: -0.01em;">
          Preguntas frecuentes sobre IA para negocios de servicio
        </h2>
      </ScrollReveal>
      <div class="space-y-0">
        {faqs.map((faq, i) => (
          <div class="border-b border-hairline">
            <button class="faq-toggle w-full text-left py-5 flex items-center justify-between gap-4 group" data-faq-index={i}>
              <span class="font-body text-body-md font-medium text-ink group-hover:text-primary transition-colors">{faq.question}</span>
              <span class="faq-icon text-muted text-xl transition-transform duration-300 flex-shrink-0">+</span>
            </button>
            <div class="faq-answer overflow-hidden max-h-0 transition-all duration-300 ease-out">
              <p class="pb-5 text-body-sm text-muted leading-relaxed">{faq.answer}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="bg-surface-dark py-16 md:py-20 px-6">
    <div class="max-w-[600px] mx-auto text-center">
      <ScrollReveal>
        <h2 class="font-display text-display-sm font-semibold text-on-dark mb-4" style="letter-spacing: -0.01em;">
          Empieza a recuperar horas esta semana
        </h2>
        <p class="text-on-dark-soft text-body-sm mb-8 leading-relaxed">
          El diagnóstico toma 60 minutos. El reporte llega en 48 horas. Si eliges implementación, tus automatizaciones quedan listas en 4 días hábiles.
        </p>
        <a
          href={waUrl}
          target="_blank"
          rel="noopener"
          class="inline-block bg-primary text-on-primary font-semibold px-8 py-4 rounded-md hover:bg-primary-active transition-all hover:scale-[1.02] text-body-sm"
        >
          Hablar con el equipo por WhatsApp →
        </a>
      </ScrollReveal>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": { "@type": "Answer", "text": faq.answer },
    })),
  })} />

  <script>
    document.querySelectorAll('.faq-toggle').forEach((btn) => {
      btn.addEventListener('click', () => {
        const answer = btn.nextElementSibling as HTMLElement;
        const icon = btn.querySelector('.faq-icon') as HTMLElement;
        const isOpen = answer.style.maxHeight && answer.style.maxHeight !== '0px';
        document.querySelectorAll('.faq-answer').forEach((a) => { (a as HTMLElement).style.maxHeight = '0px'; });
        document.querySelectorAll('.faq-icon').forEach((ic) => {
          (ic as HTMLElement).textContent = '+';
          (ic as HTMLElement).style.transform = 'rotate(0deg)';
        });
        if (!isOpen) {
          answer.style.maxHeight = answer.scrollHeight + 'px';
          icon.textContent = '−';
          icon.style.transform = 'rotate(180deg)';
        }
      });
    });
  </script>
</SegmentLayout>
