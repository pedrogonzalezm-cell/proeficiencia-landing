---
import SegmentLayout from '../layouts/SegmentLayout.astro';
import ScrollReveal from '../components/ui/ScrollReveal.astro';

const waUrl = 'https://wa.me/56964285737?text=Hola%2C%20me%20interesa%20la%20evaluaci%C3%B3n%20para%20mi%20consultor%C3%ADa%20o%20servicio%20profesional';

const quickWins = [
  {
    title: 'Propuestas de servicio generadas con IA',
    problem: 'Cada propuesta toma entre 2 y 4 horas — buscar el template, adaptar el contenido, calcular precios, revisar. Y si el cliente no acepta, ese tiempo se pierde.',
    solution: 'Construimos un flujo con Claude + Zapier donde ingresas los datos del cliente y en minutos tienes una propuesta profesional, personalizada y lista para enviar. Puedes revisarla y ajustar antes de mandar.',
    saving: '2–3 horas por propuesta ahorradas',
    tool: 'Claude AI + Zapier',
  },
  {
    title: 'Cobranza automática con seguimiento por WhatsApp',
    problem: 'Cobrar es incómodo. Muchos profesionales evitan hacer seguimiento y terminan perdiendo entre el 15% y el 30% de sus ingresos en pagos atrasados o no cobrados.',
    solution: 'Make + WhatsApp Business envía automáticamente aviso de vencimiento, recordatorio a los 3 días, y escala a un mensaje más directo si no hay pago. Tú solo recibes notificación cuando se pagó.',
    saving: 'Reduce deuda pendiente en 30–50%',
    tool: 'Make + WhatsApp Business',
  },
  {
    title: 'CRM que se actualiza solo desde el correo',
    problem: 'La gestión de clientes vive en el correo, el Excel y la cabeza del profesional. Cuando hay 20 o más clientes activos, algo siempre se cae.',
    solution: 'Conectamos HubSpot Free con tu correo mediante Zapier. Cada email con un cliente crea o actualiza el registro automáticamente. Puedes ver en segundos el historial de cada cliente.',
    saving: '1 hora diaria en gestión de clientes',
    tool: 'HubSpot Free + Zapier',
  },
];

const faqs = [
  {
    question: '¿Funciona para una consultoría pequeña de 2 a 5 personas?',
    answer: 'Es exactamente para ese tamaño. Las automatizaciones que instalamos no requieren equipo técnico ni infraestructura compleja. Hemos trabajado con contadores, abogados, arquitectos e ingenieros que operan solos o en equipos pequeños. Las herramientas cuestan entre $30 y $80 USD al mes en total.',
  },
  {
    question: '¿Cómo automatizo las propuestas sin perder el toque personal?',
    answer: 'La IA genera la estructura y el contenido base desde tu template y los datos del cliente, pero tú revisas y apruebas antes de enviar. El resultado es una propuesta personalizada lista en minutos — no un texto genérico. El toque personal lo pones tú; la IA elimina el trabajo repetitivo.',
  },
  {
    question: '¿Puedo automatizar la cobranza sin afectar la relación con mis clientes?',
    answer: 'Sí. Los mensajes se configuran con tu tono y estilo, no suenan automáticos. Además, la automatización maneja los recordatorios rutinarios, lo que te libera a ti para gestionar solo las situaciones que realmente requieren una conversación personal. Muchos clientes prefieren recibir un recordatorio automático a que los llames directamente.',
  },
  {
    question: '¿Cuánto tiempo ahorra un contador o consultor con automatización IA?',
    answer: 'En promedio, nuestros clientes de servicios profesionales recuperan entre 6 y 12 horas semanales. Las propuestas automáticas ahorran 2–3 horas por documento. La cobranza automática elimina 1–2 horas semanales de seguimiento. El CRM elimina el tiempo de buscar información de clientes. El ROI típico es de 20x a 40x en el primer mes.',
  },
];
---

<SegmentLayout
  title="IA para contadores, consultores y profesionales independientes en Chile | ProeficiencIA"
  description="Automatiza propuestas, cobranza y gestión de clientes con IA. Diagnóstico para contadores, consultores, abogados y profesionales independientes en Chile desde $199 USD."
>
  <!-- Hero -->
  <section class="bg-canvas py-20 md:py-28 px-6">
    <div class="max-w-[780px] mx-auto text-center">
      <ScrollReveal>
        <p class="text-primary font-semibold text-sm uppercase tracking-widest mb-4">Para profesionales independientes en Chile</p>
        <h1 class="font-display text-display-md md:text-display-lg font-semibold tracking-tight text-ink leading-tight mb-6" style="letter-spacing: -0.02em;">
          IA para contadores, consultores y profesionales independientes en Chile
        </h1>
        <p class="text-body-md text-muted leading-relaxed mb-8 max-w-[600px] mx-auto">
          Contadores, consultores, abogados, arquitectos, ingenieros. Si tu negocio depende de propuestas, cobranza y gestión de clientes — la IA puede recuperarte entre 6 y 12 horas semanales desde el primer mes.
        </p>
        <a
          href={waUrl}
          target="_blank"
          rel="noopener"
          class="inline-block bg-primary text-on-primary font-semibold px-8 py-4 rounded-md hover:bg-primary-active transition-all hover:scale-[1.02] text-body-sm"
        >
          Solicitar diagnóstico gratuito →
        </a>
        <p class="text-xs text-muted mt-3">Diagnóstico desde $199 USD · Implementación incluida en plan Pro</p>
      </ScrollReveal>
    </div>
  </section>

  <!-- Pain -->
  <section class="bg-surface-soft py-16 md:py-20 px-6">
    <div class="max-w-[700px] mx-auto">
      <ScrollReveal>
        <h2 class="font-display text-display-sm font-semibold tracking-tight text-ink mb-6" style="letter-spacing: -0.01em;">
          ¿Cuánto tiempo pierde tu consultoría en trabajo que no genera ingresos?
        </h2>
        <div class="space-y-4 text-body-sm text-muted leading-relaxed">
          <p>
            Un profesional independiente dedica en promedio entre el 30% y el 40% de su tiempo a tareas administrativas: redactar propuestas, hacer seguimiento de cobros, actualizar registros de clientes, responder correos rutinarios. Ese tiempo no se factura.
          </p>
          <p>
            El problema es que esas tareas son necesarias para que el negocio funcione — pero no requieren tu expertise. Requieren tiempo. Y el tiempo de un profesional vale entre $50 y $200 USD la hora.
          </p>
          <p>
            Las automatizaciones con IA hacen el trabajo administrativo en segundos, al mismo estándar que lo harías tú, para que tu tiempo se destine a lo que realmente paga: atender clientes y cerrar nuevos proyectos.
          </p>
        </div>
      </ScrollReveal>

      <ScrollReveal delay={100}>
        <div class="mt-8 grid grid-cols-3 gap-4 text-center">
          {[
            { stat: '30–40%', label: 'del tiempo en tareas administrativas' },
            { stat: '2–4 hrs', label: 'por propuesta redactada manualmente' },
            { stat: '15–30%', label: 'de ingresos perdidos por cobranza tardía' },
          ].map((item) => (
            <div class="bg-canvas rounded-lg p-4 border border-hairline">
              <div class="font-display text-display-sm font-semibold text-primary">{item.stat}</div>
              <div class="text-xs text-muted mt-1">{item.label}</div>
            </div>
          ))}
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Quick Wins -->
  <section class="bg-canvas py-16 md:py-24 px-6">
    <div class="max-w-[900px] mx-auto">
      <ScrollReveal>
        <h2 class="font-display text-display-sm font-semibold tracking-tight text-ink text-center mb-3" style="letter-spacing: -0.01em;">
          Lo que automatizamos para profesionales independientes
        </h2>
        <p class="text-body-sm text-muted text-center mb-12 max-w-[520px] mx-auto">
          Tres soluciones concretas, con herramientas específicas y ROI proyectado. No consultoría genérica — implementación real.
        </p>
      </ScrollReveal>

      <div class="space-y-6">
        {quickWins.map((qw, i) => (
          <ScrollReveal delay={i * 80}>
            <div class="bg-surface-soft rounded-xl p-6 md:p-8 border border-hairline">
              <div class="flex items-start gap-4">
                <div class="w-8 h-8 rounded-full bg-primary/10 text-primary font-semibold text-sm flex items-center justify-center flex-shrink-0 mt-0.5">
                  {i + 1}
                </div>
                <div class="flex-1">
                  <h3 class="font-display text-title-lg font-semibold text-ink mb-3">{qw.title}</h3>
                  <p class="text-body-sm text-muted mb-3"><strong class="text-body-strong">El problema:</strong> {qw.problem}</p>
                  <p class="text-body-sm text-muted mb-4"><strong class="text-body-strong">La solución:</strong> {qw.solution}</p>
                  <div class="flex flex-wrap gap-3">
                    <span class="inline-flex items-center gap-1.5 text-xs font-medium text-accent-teal bg-accent-teal/10 px-3 py-1.5 rounded-full">
                      ✓ {qw.saving}
                    </span>
                    <span class="inline-flex items-center gap-1.5 text-xs text-muted bg-surface-card px-3 py-1.5 rounded-full">
                      Herramienta: {qw.tool}
                    </span>
                  </div>
                </div>
              </div>
            </div>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="bg-surface-soft py-16 md:py-20 px-6">
    <div class="max-w-[700px] mx-auto text-center">
      <ScrollReveal>
        <h2 class="font-display text-display-sm font-semibold tracking-tight text-ink mb-10" style="letter-spacing: -0.01em;">
          ¿Cómo funciona el diagnóstico?
        </h2>
      </ScrollReveal>
      <div class="grid md:grid-cols-3 gap-6 text-left">
        {[
          { step: '1', title: 'Diagnóstico (60 min)', desc: 'Sesión por videollamada donde revisamos tus procesos actuales, herramientas y tareas repetitivas. Identificamos exactamente dónde la IA te ahorra más.' },
          { step: '2', title: 'Reporte con Quick Wins', desc: 'Recibes un documento con 3 automatizaciones priorizadas por impacto, las herramientas específicas, el costo mensual y el ROI proyectado para tu negocio.' },
          { step: '3', title: 'Implementación en 4 días', desc: 'Si optas por el plan Pro, nuestro equipo instala y configura todo. El día 5 ya estás ahorrando horas. Te capacitamos en el uso.' },
        ].map((item) => (
          <ScrollReveal delay={parseInt(item.step) * 80}>
            <div class="bg-canvas rounded-xl p-6 border border-hairline">
              <div class="font-display text-display-sm font-bold text-primary mb-3">{item.step}</div>
              <h3 class="font-body font-semibold text-ink text-body-md mb-2">{item.title}</h3>
              <p class="text-body-sm text-muted leading-relaxed">{item.desc}</p>
            </div>
          </ScrollReveal>
        ))}
      </div>
      <ScrollReveal delay={300}>
        <div class="mt-10">
          <a
            href={waUrl}
            target="_blank"
            rel="noopener"
            class="inline-block bg-primary text-on-primary font-semibold px-8 py-4 rounded-md hover:bg-primary-active transition-all hover:scale-[1.02] text-body-sm"
          >
            Solicitar diagnóstico →
          </a>
          <p class="text-xs text-muted mt-3">$199 USD · Solo diagnóstico &nbsp;|&nbsp; $497 USD · Con implementación incluida</p>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-canvas py-16 md:py-20 px-6">
    <div class="max-w-[700px] mx-auto">
      <ScrollReveal>
        <h2 class="font-display text-display-sm font-semibold tracking-tight text-ink text-center mb-10" style="letter-spacing: -0.01em;">
          Preguntas frecuentes sobre IA para profesionales independientes
        </h2>
      </ScrollReveal>
      <div class="space-y-0">
        {faqs.map((faq, i) => (
          <div class="border-b border-hairline">
            <button class="faq-toggle w-full text-left py-5 flex items-center justify-between gap-4 group" data-faq-index={i}>
              <span class="font-body text-body-md font-medium text-ink group-hover:text-primary transition-colors">{faq.question}</span>
              <span class="faq-icon text-muted text-xl transition-transform duration-300 flex-shrink-0">+</span>
            </button>
            <div class="faq-answer overflow-hidden max-h-0 transition-all duration-300 ease-out">
              <p class="pb-5 text-body-sm text-muted leading-relaxed">{faq.answer}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="bg-surface-dark py-16 md:py-20 px-6">
    <div class="max-w-[600px] mx-auto text-center">
      <ScrollReveal>
        <h2 class="font-display text-display-sm font-semibold text-on-dark mb-4" style="letter-spacing: -0.01em;">
          Empieza a recuperar horas esta semana
        </h2>
        <p class="text-on-dark-soft text-body-sm mb-8 leading-relaxed">
          El diagnóstico toma 60 minutos. El reporte llega en 48 horas. Si eliges implementación, tus automatizaciones quedan listas en 4 días hábiles.
        </p>
        <a
          href={waUrl}
          target="_blank"
          rel="noopener"
          class="inline-block bg-primary text-on-primary font-semibold px-8 py-4 rounded-md hover:bg-primary-active transition-all hover:scale-[1.02] text-body-sm"
        >
          Hablar con el equipo por WhatsApp →
        </a>
      </ScrollReveal>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": { "@type": "Answer", "text": faq.answer },
    })),
  })} />

  <script>
    document.querySelectorAll('.faq-toggle').forEach((btn) => {
      btn.addEventListener('click', () => {
        const answer = btn.nextElementSibling as HTMLElement;
        const icon = btn.querySelector('.faq-icon') as HTMLElement;
        const isOpen = answer.style.maxHeight && answer.style.maxHeight !== '0px';
        document.querySelectorAll('.faq-answer').forEach((a) => { (a as HTMLElement).style.maxHeight = '0px'; });
        document.querySelectorAll('.faq-icon').forEach((ic) => {
          (ic as HTMLElement).textContent = '+';
          (ic as HTMLElement).style.transform = 'rotate(0deg)';
        });
        if (!isOpen) {
          answer.style.maxHeight = answer.scrollHeight + 'px';
          icon.textContent = '−';
          icon.style.transform = 'rotate(180deg)';
        }
      });
    });
  </script>
</SegmentLayout>
