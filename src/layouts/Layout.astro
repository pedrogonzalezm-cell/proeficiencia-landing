---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'ProeficiencIA — Automatización con IA para PYMEs en Chile | Diagnóstico desde $199',
  description = 'Automatiza procesos y recupera horas con IA. Diagnóstico de eficiencia para PYMEs chilenas: reporte con Quick Wins e implementación incluida desde $199 USD. Sin conocimientos técnicos.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="keywords" content="automatización con IA Chile, agencia IA PYMEs Chile, implementar inteligencia artificial empresa, automatización procesos PYME, consultoría IA Chile, herramientas IA para empresas, diagnóstico IA empresarial" />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_CL" />
    <meta property="og:title" content="ProeficiencIA — Recupera horas. Recupera ganancias." />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/og-image.png" />
    <meta property="og:url" content={canonicalURL} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "ProeficiencIA",
      "description": "Diagnóstico IA por departamento para PYMEs",
      "url": "https://proeficiencia.cl",
      "priceRange": "$199-$497",
      "areaServed": "Chile",
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "itemListElement": [
          { "@type": "Offer", "name": "Diagnóstico de Eficiencia con IA", "price": "199", "priceCurrency": "USD" },
          { "@type": "Offer", "name": "Diagnóstico + Activación (implementación incluida)", "price": "497", "priceCurrency": "USD" },
          { "@type": "Offer", "name": "Mantenimiento Mensual", "price": "99", "priceCurrency": "USD" },
        ],
      },
    })} />
  </head>
  <body class="bg-canvas text-body min-h-screen">
    <slot />
  </body>
</html>