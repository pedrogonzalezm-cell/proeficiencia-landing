---
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  keywords?: string;
}

const { title, description, pubDate, keywords } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const dateStr = pubDate.toLocaleDateString('es-CL', { year: 'numeric', month: 'long', day: 'numeric' });
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:type" content="article" />
    <meta property="og:locale" content="es_CL" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="google-site-verification" content="0u9KiiCsuUJtMLVy5bvPAHkzFSqhfeW71X3W6JJo_Xc" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": title,
      "description": description,
      "datePublished": pubDate.toISOString(),
      "author": { "@type": "Organization", "name": "ProeficiencIA" },
      "publisher": {
        "@type": "Organization",
        "name": "ProeficiencIA",
        "url": "https://proeficiencia.cl",
      },
      "url": canonicalURL,
    })} />
  </head>
  <body class="bg-canvas text-body min-h-screen">
    <header id="blog-navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-transparent">
      <div class="max-w-[1200px] mx-auto px-6 flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-2" aria-label="ProeficiencIA">
          <img src="/logo.svg" alt="ProeficiencIA" class="h-8" />
        </a>
        <div class="flex items-center gap-4">
          <a href="/blog" class="hidden md:block text-sm font-medium text-ink hover:text-primary transition-colors">
            Blog
          </a>
          <a
            href="https://wa.me/56964285737?text=Hola%2C%20me%20interesa%20la%20evaluaci%C3%B3n"
            target="_blank"
            rel="noopener"
            class="bg-primary text-on-primary text-sm font-semibold px-5 py-2.5 rounded-md hover:bg-primary-active transition-all hover:scale-[1.02]"
          >
            Solicitar evaluación
          </a>
        </div>
      </div>
    </header>

    <main class="pt-16">
      <!-- Article header -->
      <div class="bg-surface-soft py-16 md:py-20 px-6">
        <div class="max-w-[720px] mx-auto">
          <a href="/blog" class="text-xs text-muted hover:text-primary transition-colors mb-6 inline-block">← Volver al blog</a>
          <h1 class="font-display text-display-sm md:text-display-md font-semibold tracking-tight text-ink leading-tight mb-4" style="letter-spacing: -0.02em;">
            {title}
          </h1>
          <p class="text-body-sm text-muted">{dateStr} · ProeficiencIA</p>
        </div>
      </div>

      <!-- Article body -->
      <article class="px-6 py-12 md:py-16">
        <div class="max-w-[720px] mx-auto prose-article">
          <slot />
        </div>
      </article>

      <!-- CTA -->
      <div class="bg-surface-soft px-6 py-12 mb-0">
        <div class="max-w-[600px] mx-auto text-center">
          <p class="font-display text-display-sm font-semibold text-ink mb-3" style="letter-spacing: -0.01em;">¿Quieres aplicar esto en tu empresa?</p>
          <p class="text-body-sm text-muted mb-6">Diagnóstico de eficiencia con IA para PYMEs chilenas. Reporte con Quick Wins en 48 horas desde $199 USD.</p>
          <a
            href="https://wa.me/56964285737?text=Hola%2C%20le%C3%AD%20el%20blog%20y%20me%20interesa%20el%20diagn%C3%B3stico"
            target="_blank"
            rel="noopener"
            class="inline-block bg-primary text-on-primary font-semibold px-8 py-4 rounded-md hover:bg-primary-active transition-all hover:scale-[1.02] text-body-sm"
          >
            Solicitar diagnóstico →
          </a>
        </div>
      </div>
    </main>

    <Footer />
    <WhatsAppButton />

    <script>
      const navbar = document.getElementById('blog-navbar');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 80) {
          navbar?.classList.add('bg-canvas', 'border-b', 'border-hairline');
          navbar?.classList.remove('bg-transparent');
        } else {
          navbar?.classList.remove('bg-canvas', 'border-b', 'border-hairline');
          navbar?.classList.add('bg-transparent');
        }
      });
    </script>

    <style>
      .prose-article h2 {
        font-family: var(--font-display);
        font-size: var(--text-display-sm);
        font-weight: 600;
        color: var(--color-ink);
        margin-top: 2.5rem;
        margin-bottom: 1rem;
        letter-spacing: -0.01em;
        line-height: 1.2;
      }
      .prose-article h3 {
        font-family: var(--font-display);
        font-size: var(--text-title-lg);
        font-weight: 600;
        color: var(--color-ink);
        margin-top: 2rem;
        margin-bottom: 0.75rem;
      }
      .prose-article p {
        font-size: var(--text-body-sm);
        color: var(--color-muted);
        line-height: 1.75;
        margin-bottom: 1.25rem;
      }
      .prose-article ul, .prose-article ol {
        padding-left: 1.5rem;
        margin-bottom: 1.25rem;
      }
      .prose-article li {
        font-size: var(--text-body-sm);
        color: var(--color-muted);
        line-height: 1.75;
        margin-bottom: 0.5rem;
      }
      .prose-article strong {
        color: var(--color-body-strong);
        font-weight: 600;
      }
      .prose-article a {
        color: var(--color-primary);
        text-decoration: underline;
      }
      .prose-article blockquote {
        border-left: 3px solid var(--color-primary);
        padding-left: 1.25rem;
        margin: 1.5rem 0;
        font-style: italic;
        color: var(--color-body-strong);
      }
      .prose-article hr {
        border: none;
        border-top: 1px solid var(--color-hairline);
        margin: 2.5rem 0;
      }
    </style>
  </body>
</html>
