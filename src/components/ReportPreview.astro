---
import ScrollReveal from './ui/ScrollReveal.astro';
---

<section class="bg-surface-dark py-20 md:py-28 px-6">
  <div class="max-w-[1200px] mx-auto">

    <ScrollReveal>
      <div class="text-center mb-4">
        <span class="text-xs font-semibold tracking-widest text-primary uppercase">Lo que recibes</span>
      </div>
      <h2 class="font-display text-display-md font-semibold text-on-dark text-center mb-4" style="letter-spacing:-0.01em;">
        Así se ve tu reporte
      </h2>
      <p class="text-on-dark-soft text-body-sm text-center max-w-xl mx-auto mb-16">
        Un informe profesional con diagnóstico, soluciones concretas y plan de implementación — no recomendaciones genéricas.
      </p>
    </ScrollReveal>

    <!-- Fila 1: métricas + solución ejemplo -->
    <div class="grid md:grid-cols-2 gap-6 mb-6">

      <!-- Métricas de impacto -->
      <ScrollReveal delay="0">
        <div class="bg-surface-dark-elevated rounded-xl overflow-hidden border border-white/5 h-full">
          <div class="px-6 py-4 border-b border-white/5">
            <span class="text-xs font-semibold tracking-widest text-primary uppercase">Tu oportunidad</span>
          </div>
          <div class="p-6">
            <p class="text-on-dark-soft text-xs mb-6">Quick wins implementables en 4 días</p>
            <div class="grid grid-cols-2 gap-6">
              <div>
                <p class="font-display text-5xl font-bold text-on-dark">80</p>
                <p class="text-primary text-sm font-semibold mt-1">horas recuperables</p>
                <p class="text-on-dark-soft text-xs">por mes</p>
              </div>
              <div>
                <p class="font-display text-5xl font-bold text-on-dark">$4.2M</p>
                <p class="text-primary text-sm font-semibold mt-1">valor mensual</p>
                <p class="text-on-dark-soft text-xs">recuperado (CLP)</p>
              </div>
              <div>
                <p class="font-display text-3xl font-bold text-on-dark-soft">−$85K</p>
                <p class="text-on-dark-soft text-sm mt-1">en herramientas</p>
              </div>
              <div>
                <p class="font-display text-3xl font-bold text-accent-green">=$4.1M</p>
                <p class="text-on-dark-soft text-sm mt-1">ahorro neto/mes</p>
              </div>
            </div>
          </div>
        </div>
      </ScrollReveal>

      <!-- Solución ejemplo -->
      <ScrollReveal delay="100">
        <div class="bg-surface-dark-elevated rounded-xl overflow-hidden border border-white/5 h-full">
          <div class="px-6 py-4 border-b border-white/5 flex items-center justify-between">
            <span class="text-xs font-semibold tracking-widest text-primary uppercase">Solución 1 de 3</span>
            <span class="text-xs bg-accent-green/20 text-accent-green px-2 py-0.5 rounded-full font-medium">Plug-and-play ✓</span>
          </div>
          <div class="p-6">
            <h3 class="font-display text-xl font-semibold text-on-dark mb-2">
              ChatGPT Plus — Asistente de marca que escribe como tú
            </h3>
            <p class="text-on-dark-soft text-sm mb-5 leading-relaxed">
              <strong class="text-on-dark">Problema:</strong> 6-8 hrs/sem creando contenido con voz de marca inconsistente. Sin guía documentada, cada persona escribe distinto.
            </p>
            <div class="grid grid-cols-2 gap-3">
              <div class="bg-surface-dark rounded-lg p-3">
                <p class="text-xs text-on-dark-soft mb-1">Costo mensual</p>
                <p class="text-on-dark font-semibold text-sm">USD $20</p>
              </div>
              <div class="bg-surface-dark rounded-lg p-3">
                <p class="text-xs text-on-dark-soft mb-1">Setup</p>
                <p class="text-on-dark font-semibold text-sm">30 minutos</p>
              </div>
              <div class="bg-surface-dark rounded-lg p-3 col-span-2">
                <p class="text-xs text-on-dark-soft mb-1">Tiempo ahorrado</p>
                <p class="text-primary font-bold text-sm">7 hrs/semana</p>
              </div>
            </div>
          </div>
        </div>
      </ScrollReveal>
    </div>

    <!-- Fila 2: plan de días + matriz -->
    <div class="grid md:grid-cols-2 gap-6">

      <!-- Plan de 4 días -->
      <ScrollReveal delay="0">
        <div class="bg-surface-dark-elevated rounded-xl overflow-hidden border border-white/5">
          <div class="px-6 py-4 border-b border-white/5">
            <span class="text-xs font-semibold tracking-widest text-primary uppercase">Plan de implementación</span>
          </div>
          <div class="p-6">
            <h3 class="font-display text-xl font-semibold text-on-dark mb-6">Tu Plan de 4 Días</h3>
            <div class="relative">
              <div class="absolute left-4 top-0 bottom-0 w-px bg-white/10"></div>
              <div class="space-y-5">
                {[
                  { day: '1', title: 'ChatGPT Plus', desc: 'Documenta voz de marca + crea Custom Instructions + valida con contenido real.' },
                  { day: '2', title: 'Reportes Automáticos', desc: 'Conecta cuentas + configura templates + programa envío automático semanal.' },
                  { day: '3', title: 'Chatbot FAQ', desc: 'Diseña flujos de preguntas frecuentes + activa bot 24/7 en tus canales.' },
                  { day: '4', title: 'Integración y validación', desc: 'Conecta las 3 herramientas + capacita al equipo + documenta procesos.' },
                ].map(step => (
                  <div class="flex gap-4 pl-2">
                    <div class="w-6 h-6 rounded-full bg-primary text-white text-xs font-bold flex items-center justify-center flex-shrink-0 z-10">
                      {step.day}
                    </div>
                    <div>
                      <p class="text-on-dark font-semibold text-sm">{step.title}</p>
                      <p class="text-on-dark-soft text-xs mt-0.5 leading-relaxed">{step.desc}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
            <p class="mt-6 text-center text-xs text-on-dark-soft">4 días. <span class="text-primary font-bold">80 horas recuperadas al mes.</span> Empieza hoy.</p>
          </div>
        </div>
      </ScrollReveal>

      <!-- Matriz esfuerzo vs impacto -->
      <ScrollReveal delay="100">
        <div class="bg-surface-dark-elevated rounded-xl overflow-hidden border border-white/5">
          <div class="px-6 py-4 border-b border-white/5">
            <span class="text-xs font-semibold tracking-widest text-primary uppercase">Priorización</span>
          </div>
          <div class="p-6">
            <h3 class="font-display text-xl font-semibold text-on-dark mb-2">Esfuerzo vs. Impacto</h3>
            <p class="text-on-dark-soft text-xs mb-5">Con recursos limitados, la clave es saber dónde invertir primero.</p>
            <div class="grid grid-cols-2 gap-2 text-xs">
              <div class="bg-primary/15 border border-primary/30 rounded-lg p-3">
                <p class="text-primary font-bold mb-1">⚡ QUICK WINS</p>
                <p class="text-on-dark-soft leading-relaxed">Alto impacto, bajo esfuerzo. Empezamos aquí.</p>
                <ul class="mt-2 space-y-1 text-on-dark-soft">
                  <li>· Asistente de contenido</li>
                  <li>· Reportes automáticos</li>
                  <li>· FAQ automatizado</li>
                </ul>
              </div>
              <div class="bg-white/5 border border-white/10 rounded-lg p-3">
                <p class="text-on-dark font-bold mb-1">🏗 MAJOR PROJECTS</p>
                <p class="text-on-dark-soft leading-relaxed">Alto impacto, más esfuerzo. Fase 2.</p>
                <ul class="mt-2 space-y-1 text-on-dark-soft">
                  <li>· CRM automático</li>
                  <li>· IA para clientes</li>
                </ul>
              </div>
              <div class="bg-white/5 border border-white/10 rounded-lg p-3">
                <p class="text-on-dark-soft font-bold mb-1">📋 FILL-INS</p>
                <p class="text-on-dark-soft leading-relaxed">Bajo impacto, bajo esfuerzo.</p>
                <ul class="mt-2 space-y-1 text-on-dark-soft">
                  <li>· Templates en Docs</li>
                </ul>
              </div>
              <div class="bg-white/5 border border-white/10 rounded-lg p-3 opacity-50">
                <p class="text-on-dark-soft font-bold mb-1">✗ IGNORAR</p>
                <p class="text-on-dark-soft leading-relaxed">Bajo impacto, alto esfuerzo.</p>
                <ul class="mt-2 space-y-1 text-on-dark-soft">
                  <li>· Migración de sistemas</li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </ScrollReveal>
    </div>

    <!-- CTA -->
    <ScrollReveal delay="200">
      <div class="mt-12 text-center">
        <p class="text-on-dark-soft text-sm mb-4">Este reporte es tuyo después de tu Evaluación Integral.</p>
        <a
          href="https://cal.com/proeficiencia/15min"
          target="_blank"
          rel="noopener"
          class="inline-block bg-primary text-on-primary text-sm font-semibold px-8 py-3 rounded-md hover:bg-primary-active transition-all hover:scale-[1.02]"
        >
          Agenda tu llamada gratuita — 15 min
        </a>
      </div>
    </ScrollReveal>

  </div>
</section>
