---
interface Props {
  variant?: 'surface-card' | 'dark-elevated' | 'canvas';
  class?: string;
}

const {
  variant = 'surface-card',
  class: className = '',
} = Astro.props;

const variantClasses = {
  'surface-card': 'bg-surface-card text-ink rounded-lg p-8',
  'dark-elevated': 'bg-surface-dark-elevated text-on-dark rounded-lg p-8',
  canvas: 'bg-canvas text-ink border border-hairline rounded-lg p-8',
};

const classes = `${variantClasses[variant]} ${className}`;
---

<div class={classes}>
  <slot />
</div>