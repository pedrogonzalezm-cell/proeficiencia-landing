---
interface Props {
  variant?: 'primary' | 'secondary' | 'on-dark';
  href?: string;
  onclick?: string;
  type?: 'button' | 'submit';
  class?: string;
  id?: string;
}

const {
  variant = 'primary',
  href,
  onclick,
  type = 'button',
  class: className = '',
  id,
} = Astro.props;

const baseClasses = 'inline-flex items-center justify-center font-body text-sm font-semibold px-5 py-3 rounded-md transition-all duration-150 cursor-pointer select-none';

const variantClasses = {
  primary: 'bg-primary text-on-primary hover:bg-primary-active hover:scale-[1.02]',
  secondary: 'bg-canvas text-ink border border-hairline hover:bg-surface-card hover:scale-[1.02]',
  'on-dark': 'bg-surface-dark-elevated text-on-dark hover:bg-surface-dark-soft hover:scale-[1.02]',
};

const classes = `${baseClasses} ${variantClasses[variant]} ${className}`;

const Tag = href ? 'a' : 'button';
---

{href ? (
  <a href={href} class={classes} id={id} onclick={onclick}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} id={id} onclick={onclick}>
    <slot />
  </button>
)}