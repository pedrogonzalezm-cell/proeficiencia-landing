---
import ScrollReveal from './ui/ScrollReveal.astro';

const team = [
  {
    name: 'Pedro',
    role: 'Fundador · Finanzas',
    department: 'Finanzas',
    bio: 'MBA con 13+ años en FP&A y controlling en multinacionales como Thermo Fisher Scientific y Sandvik. Especialista en automatización de reportes, Power BI y AI aplicada a finanzas. Lidera la transformación financiera de PYMEs con herramientas concretas y medibles.',
    tags: ['FP&A', 'Power BI', 'AI Finanzas'],
    photo: '/team-pedro.jpg',
    initials: 'PG',
    linkedin: null,
  },
  {
    name: 'Juanita',
    role: 'Especialista · Ventas',
    department: 'Ventas',
    bio: '10+ años liderando equipos comerciales en PYMEs y startups chilenas. Experta en CRM, automatización de pipeline y estrategias de conversión. Ha ayudado a más de 30 equipos de ventas a reducir su ciclo de cierre con herramientas de IA.',
    tags: ['CRM', 'Pipeline', 'Lead Scoring'],
    photo: '/team-juanita.jpg',
    initials: 'JM',
    linkedin: null,
  },
  {
    name: 'Nicolás',
    role: 'Especialista · Marketing',
    department: 'Marketing',
    bio: 'Especialista en marketing digital y contenido con IA. Experiencia en agencias y empresas de consumo masivo. Enfocado en automatización de canales, creación de contenido escalable y crecimiento orgánico para PYMEs.',
    tags: ['Contenido IA', 'Social Media', 'SEO'],
    photo: '/team-nicolas.jpg',
    initials: 'NV',
    linkedin: null,
  },
];
---

<section class="bg-canvas py-20 md:py-28 px-6">
  <div class="max-w-[1200px] mx-auto">
    <ScrollReveal>
      <div class="text-center mb-12">
        <span class="text-xs font-semibold tracking-widest text-primary uppercase">El equipo</span>
        <h2 class="font-display text-display-md font-semibold tracking-tight text-ink mt-3" style="letter-spacing: -0.01em;">
          Expertos en tu área
        </h2>
        <p class="mt-3 text-muted text-body-sm max-w-lg mx-auto">
          Cada evaluación la lidera un especialista con experiencia real en el departamento que analizamos.
        </p>
      </div>
    </ScrollReveal>

    <div class="grid md:grid-cols-3 gap-8">
      {team.map((member, i) => (
        <ScrollReveal delay={i * 100} class="h-full">
          <div class="bg-surface-card rounded-xl p-8 flex flex-col items-center text-center border border-hairline hover:border-primary/30 transition-all h-full">

            <!-- Foto o inicial -->
            <div class="w-24 h-24 rounded-full overflow-hidden mb-5 border-2 border-primary/20 flex-shrink-0">
              {member.photo ? (
                <img
                  src={member.photo}
                  alt={member.name}
                  class="w-full h-full object-cover object-top"
                />
              ) : (
                <div class="w-full h-full bg-surface-dark flex items-center justify-center">
                  <span class="font-display text-2xl font-bold text-primary">{member.initials}</span>
                </div>
              )}
            </div>

            <!-- Info -->
            <h3 class="font-display text-title-lg font-semibold text-ink">{member.name}</h3>
            <p class="text-xs font-semibold text-primary tracking-wider uppercase mt-1">{member.role}</p>

            <p class="mt-4 text-body-sm text-muted leading-relaxed">{member.bio}</p>

            <!-- Tags -->
            <div class="mt-5 flex flex-wrap gap-2 justify-center">
              {member.tags.map(tag => (
                <span class="text-xs bg-surface-card border border-hairline text-muted px-3 py-1 rounded-full">
                  {tag}
                </span>
              ))}
            </div>

            <!-- LinkedIn -->
            {member.linkedin && (
              <a
                href={member.linkedin}
                target="_blank"
                rel="noopener"
                class="mt-5 inline-flex items-center gap-1.5 text-xs text-muted hover:text-primary transition-colors"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
                Ver LinkedIn
              </a>
            )}
          </div>
        </ScrollReveal>
      ))}
    </div>
  </div>
</section>
