---
import ScrollReveal from './ui/ScrollReveal.astro';

const steps = [
  {
    number: '1',
    title: 'Diagnóstico',
    subtitle: 'Quiz 3 min o Evaluación 45 min',
    description: 'Descubre cuánto tiempo y dinero pierdes en tareas repetitivas.',
  },
  {
    number: '2',
    title: 'Plan de Acción',
    subtitle: 'Reporte personalizado + ROI',
    description: 'Recibe un plan con quick wins inmediatos y proyección de retorno.',
  },
  {
    number: '3',
    title: 'Implementación',
    subtitle: 'Te ayudamos a ponerlo en marcha',
    description: 'No necesitas ser experto en tecnología. Nosotros lo hacemos por ti.',
  },
];
---

<section class="bg-canvas py-20 md:py-28 px-6">
  <div class="max-w-[1200px] mx-auto">
    <ScrollReveal>
      <h2 class="font-display text-display-md font-semibold tracking-tight text-ink text-center" style="letter-spacing: -0.01em;">
        Así de simple
      </h2>
    </ScrollReveal>

    <div class="mt-12 grid md:grid-cols-3 gap-8">
      {steps.map((step, i) => (
        <ScrollReveal delay={i * 100}>
          <div class="text-center">
            <div class="w-12 h-12 rounded-full bg-primary text-on-primary flex items-center justify-center text-lg font-display font-bold mx-auto">
              {step.number}
            </div>
            <h3 class="mt-4 font-display text-title-lg font-semibold text-ink">{step.title}</h3>
            <p class="mt-1 text-caption uppercase tracking-wider text-primary font-semibold">{step.subtitle}</p>
            <p class="mt-3 text-body-sm text-muted">{step.description}</p>
          </div>
        </ScrollReveal>
      ))}
    </div>

    <div class="mt-12 text-center">
      <button
        class="bg-primary text-on-primary text-sm font-semibold px-8 py-3 rounded-md hover:bg-primary-active transition-all hover:scale-[1.02]"
        data-quiz-trigger
      >
        Haz el quiz — 3 min
      </button>
    </div>
  </div>
</section>