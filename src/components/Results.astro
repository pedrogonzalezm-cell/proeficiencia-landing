---
import ScrollReveal from './ui/ScrollReveal.astro';
---

<section class="bg-surface-card py-20 md:py-28 px-6">
  <div class="max-w-[1200px] mx-auto">
    <ScrollReveal>
      <h2 class="font-display text-display-md font-semibold tracking-tight text-ink text-center" style="letter-spacing: -0.01em;">
        Empresas PYMEs pierden 8+ horas por semana en tareas que la IA puede automatizar
      </h2>
    </ScrollReveal>

    <div class="mt-12 grid md:grid-cols-2 gap-6">
      <ScrollReveal delay="0">
        <div class="bg-canvas rounded-lg p-8 border border-hairline">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-error text-2xl">&#10060;</span>
            <h3 class="font-display text-title-lg font-semibold text-ink">Antes</h3>
          </div>
          <p class="font-mono text-3xl text-error font-semibold mb-2">2 horas</p>
          <p class="text-body-sm text-muted">cada lunes en reportes manuales</p>
          <div class="mt-4 pt-4 border-t border-hairline">
            <p class="text-body-sm text-muted">Manual, propenso a errores, inconsistente</p>
          </div>
        </div>
      </ScrollReveal>

      <ScrollReveal delay="100">
        <div class="bg-canvas rounded-lg p-8 border border-hairline">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-accent-green text-2xl">&#10004;&#65039;</span>
            <h3 class="font-display text-title-lg font-semibold text-ink">Después</h3>
          </div>
          <p class="font-mono text-3xl text-primary font-semibold mb-2">30 minutos</p>
          <p class="text-body-sm text-muted">automáticos cada semana</p>
          <div class="mt-4 pt-4 border-t border-hairline">
            <p class="text-body-sm text-muted">Automático, sin errores, siempre a tiempo</p>
          </div>
        </div>
      </ScrollReveal>
    </div>

    <ScrollReveal delay="200">
      <p class="mt-8 text-center font-mono text-body-md text-primary">
        USD $42/mes en herramientas = USD $800/mes en horas recuperadas
      </p>
    </ScrollReveal>
  </div>
</section>