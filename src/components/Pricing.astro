---
import ScrollReveal from './ui/ScrollReveal.astro';
---

<section id="precios" class="bg-primary py-20 md:py-28 px-6">
  <div class="max-w-[1200px] mx-auto">
    <ScrollReveal>
      <div class="text-center mb-12">
        <h2 class="font-display text-display-sm font-semibold text-on-primary" style="letter-spacing: -0.01em;">
          Evaluación Integral
        </h2>
        <p class="mt-3 text-on-primary/70 text-body-sm max-w-xl mx-auto">
          Un diagnóstico profesional de tus procesos con un plan concreto de implementación con IA.
        </p>
      </div>
    </ScrollReveal>

    <div class="max-w-4xl mx-auto grid md:grid-cols-2 gap-8 items-start">

      <!-- Card precio -->
      <ScrollReveal delay="0">
        <div class="bg-on-primary/10 rounded-xl p-8 border border-on-primary/20">
          <p class="text-xs font-semibold tracking-widest text-on-primary/60 uppercase mb-4">Inversión</p>

          <div class="flex items-end gap-2 mb-1">
            <span class="font-mono text-5xl font-bold text-on-primary">10 – 18</span>
            <span class="font-mono text-2xl font-semibold text-on-primary/80 mb-1">UF</span>
          </div>

          <p id="clp-ref" class="text-sm text-on-primary/60 mb-6">Calculando valor en pesos...</p>

          <ul class="space-y-3 mb-8">
            <li class="flex items-start gap-3 text-on-primary/80 text-sm">
              <span class="text-accent-green mt-0.5">&#10003;</span>
              Diagnóstico de procesos (Ventas, Finanzas o Marketing)
            </li>
            <li class="flex items-start gap-3 text-on-primary/80 text-sm">
              <span class="text-accent-green mt-0.5">&#10003;</span>
              Reporte escrito con hallazgos y oportunidades de automatización
            </li>
            <li class="flex items-start gap-3 text-on-primary/80 text-sm">
              <span class="text-accent-green mt-0.5">&#10003;</span>
              Plan de implementación priorizado con ROI estimado
            </li>
            <li class="flex items-start gap-3 text-on-primary/80 text-sm">
              <span class="text-accent-green mt-0.5">&#10003;</span>
              Sesión de presentación de resultados (45 min)
            </li>
            <li class="flex items-start gap-3 text-on-primary/80 text-sm">
              <span class="text-accent-green mt-0.5">&#10003;</span>
              Recomendación de herramientas específicas para tu empresa
            </li>
          </ul>

          <a
            href="https://wa.me/56964285737?text=Hola%2C%20me%20interesa%20la%20evaluaci%C3%B3n"
            target="_blank"
            rel="noopener"
            class="block text-center bg-on-primary text-primary text-sm font-semibold px-6 py-3 rounded-md hover:bg-canvas transition-all hover:scale-[1.02]"
          >
            Envíanos un Mensaje por WhatsApp
          </a>

          <p class="mt-3 text-center text-xs text-on-primary/50">Sin compromiso. Te cotizamos exacto en el chat.</p>
        </div>
      </ScrollReveal>

      <!-- Factores que determinan el precio -->
      <ScrollReveal delay="100">
        <div class="space-y-4">
          <p class="text-xs font-semibold tracking-widest text-on-primary/60 uppercase">¿Qué determina el precio?</p>

          <div class="bg-on-primary/10 rounded-xl p-6 border border-on-primary/20">
            <div class="flex items-center gap-3 mb-2">
              <span class="text-2xl">🏢</span>
              <h3 class="font-semibold text-on-primary text-sm">Número de áreas a evaluar</h3>
            </div>
            <p class="text-on-primary/60 text-xs leading-relaxed">
              1 área (Ventas, Finanzas o Marketing) → desde 10 UF.<br/>
              Cada área adicional suma al alcance y al reporte.
            </p>
          </div>

          <div class="bg-on-primary/10 rounded-xl p-6 border border-on-primary/20">
            <div class="flex items-center gap-3 mb-2">
              <span class="text-2xl">👥</span>
              <h3 class="font-semibold text-on-primary text-sm">Tamaño de tu equipo</h3>
            </div>
            <p class="text-on-primary/60 text-xs leading-relaxed">
              A más personas, más procesos que mapear.<br/>
              Empresas de 5-15 personas vs 30-50 tienen alcances distintos.
            </p>
          </div>

          <div class="bg-on-primary/10 rounded-xl p-6 border border-on-primary/20">
            <div class="flex items-center gap-3 mb-2">
              <span class="text-2xl">⚙️</span>
              <h3 class="font-semibold text-on-primary text-sm">Complejidad de sistemas actuales</h3>
            </div>
            <p class="text-on-primary/60 text-xs leading-relaxed">
              Si ya usas CRM, ERP u otras herramientas, el análisis de integración es más profundo.
            </p>
          </div>

          <p class="text-on-primary/50 text-xs pt-2">
            * Valor expresado en UF (Unidad de Fomento). <span id="uf-date"></span>
          </p>
        </div>
      </ScrollReveal>

    </div>
  </div>
</section>

<script>
  async function loadUF() {
    try {
      const res = await fetch('https://mindicador.cl/api/uf');
      const data = await res.json();
      const uf = data.serie[0].valor as number;
      const fecha = new Date(data.serie[0].fecha).toLocaleDateString('es-CL', { day: 'numeric', month: 'long', year: 'numeric' });

      const clpMin = Math.round(uf * 10 / 1000) * 1000;
      const clpMax = Math.round(uf * 18 / 1000) * 1000;

      const fmt = (n: number) => n.toLocaleString('es-CL');

      const clpRef = document.getElementById('clp-ref');
      const ufDate = document.getElementById('uf-date');

      if (clpRef) clpRef.textContent = `≈ $${fmt(clpMin)} – $${fmt(clpMax)} pesos chilenos`;
      if (ufDate) ufDate.textContent = `1 UF = $${fmt(Math.round(uf))} al ${fecha}.`;
    } catch {
      const clpRef = document.getElementById('clp-ref');
      if (clpRef) clpRef.textContent = 'Ver valor referencial en cal.com/proeficiencia/15min';
    }
  }

  loadUF();
</script>
