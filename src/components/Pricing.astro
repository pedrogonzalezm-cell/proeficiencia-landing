---
import ScrollReveal from './ui/ScrollReveal.astro';
---

<section id="precios" class="bg-primary py-20 md:py-28 px-6">
  <div class="max-w-[1200px] mx-auto">
    <ScrollReveal>
      <div class="text-center mb-14">
        <h2 class="font-display text-display-sm font-semibold text-on-primary" style="letter-spacing: -0.01em;">
          Elige tu punto de partida
        </h2>
        <p class="mt-3 text-on-primary/70 text-body-sm max-w-xl mx-auto">
          Diagnóstico profesional con IA. Tú decides si quieres solo el mapa, o que lo implementemos juntos.
        </p>
      </div>
    </ScrollReveal>

    <div class="max-w-5xl mx-auto grid md:grid-cols-3 gap-6 items-start">

      <!-- Tier 1 - Solo Diagnóstico -->
      <ScrollReveal delay="0">
        <div class="bg-on-primary/10 rounded-xl p-8 border border-on-primary/20 flex flex-col h-full">
          <p class="text-xs font-semibold tracking-widest text-on-primary/60 uppercase mb-4">Diagnóstico</p>
          <div class="flex items-end gap-1.5 mb-1">
            <span class="font-mono text-4xl font-bold text-on-primary">$199</span>
            <span class="text-on-primary/60 text-sm mb-1">USD</span>
          </div>
          <p class="text-xs text-on-primary/50 mb-6">pago único</p>
          <ul class="space-y-3 mb-8 flex-1">
            <li class="flex items-start gap-3 text-on-primary/80 text-sm">
              <span class="text-accent-green mt-0.5">&#10003;</span>
              Entrevista de diagnóstico (60 min)
            </li>
            <li class="flex items-start gap-3 text-on-primary/80 text-sm">
              <span class="text-accent-green mt-0.5">&#10003;</span>
              Reporte con 3 Quick Wins priorizados
            </li>
            <li class="flex items-start gap-3 text-on-primary/80 text-sm">
              <span class="text-accent-green mt-0.5">&#10003;</span>
              Análisis de ROI proyectado
            </li>
            <li class="flex items-start gap-3 text-on-primary/80 text-sm">
              <span class="text-accent-green mt-0.5">&#10003;</span>
              Guía de implementación paso a paso
            </li>
          </ul>
          <a
            href="https://wa.me/56964285737?text=Hola%2C%20me%20interesa%20el%20plan%20Diagn%C3%B3stico"
            target="_blank"
            rel="noopener"
            class="block text-center border border-on-primary/50 text-on-primary text-sm font-semibold px-6 py-3 rounded-md hover:bg-on-primary/10 transition-all"
          >
            Comenzar
          </a>
        </div>
      </ScrollReveal>

      <!-- Tier 2 - Diagnóstico + Activación (RECOMENDADO) -->
      <ScrollReveal delay="100">
        <div class="bg-on-primary rounded-xl p-8 border-2 border-on-primary flex flex-col h-full relative shadow-lg md:-mt-2 md:-mb-2">
          <div class="absolute -top-4 left-1/2 -translate-x-1/2">
            <span class="bg-primary text-on-primary text-xs font-bold px-4 py-1.5 rounded-full whitespace-nowrap tracking-wide">&#9733; RECOMENDADO</span>
          </div>
          <p class="text-xs font-semibold tracking-widest text-primary/60 uppercase mb-4 mt-3">Diagnóstico + Activación</p>
          <div class="flex items-end gap-1.5 mb-1">
            <span class="font-mono text-4xl font-bold text-ink">$497</span>
            <span class="text-body text-sm mb-1 opacity-60">USD</span>
          </div>
          <p class="text-xs text-body opacity-40 mb-6">pago único</p>
          <ul class="space-y-3 mb-8 flex-1">
            <li class="flex items-start gap-3 text-body-strong text-sm">
              <span class="text-accent-green mt-0.5">&#10003;</span>
              Todo lo del plan Diagnóstico
            </li>
            <li class="flex items-start gap-3 text-body-strong text-sm">
              <span class="text-accent-green mt-0.5">&#10003;</span>
              Implementación de los 3 Quick Wins por nuestro equipo
            </li>
            <li class="flex items-start gap-3 text-body-strong text-sm">
              <span class="text-accent-green mt-0.5">&#10003;</span>
              Sesión de entrega y capacitación (30 min)
            </li>
            <li class="flex items-start gap-3 text-body-strong text-sm">
              <span class="text-accent-green mt-0.5">&#10003;</span>
              2 semanas de soporte por WhatsApp
            </li>
          </ul>
          <a
            href="https://wa.me/56964285737?text=Hola%2C%20me%20interesa%20el%20plan%20Diagn%C3%B3stico%20%2B%20Activaci%C3%B3n"
            target="_blank"
            rel="noopener"
            class="block text-center bg-primary text-on-primary text-sm font-semibold px-6 py-3 rounded-md hover:bg-primary-active transition-all hover:scale-[1.02]"
          >
            Quiero que lo implementen
          </a>
          <p class="mt-3 text-center text-xs text-body opacity-40">Empiezas a ahorrar desde el día 5.</p>
        </div>
      </ScrollReveal>

      <!-- Tier 3 - Mantenimiento Mensual -->
      <ScrollReveal delay="200">
        <div class="bg-on-primary/10 rounded-xl p-8 border border-on-primary/20 flex flex-col h-full">
          <p class="text-xs font-semibold tracking-widest text-on-primary/60 uppercase mb-4">Mantenimiento</p>
          <div class="flex items-end gap-1.5 mb-1">
            <span class="font-mono text-4xl font-bold text-on-primary">$99</span>
            <span class="text-on-primary/60 text-sm mb-1">USD/mes</span>
          </div>
          <p class="text-xs text-on-primary/50 mb-6">requiere plan anterior</p>
          <ul class="space-y-3 mb-8 flex-1">
            <li class="flex items-start gap-3 text-on-primary/80 text-sm">
              <span class="text-accent-green mt-0.5">&#10003;</span>
              Check-in mensual (30 min)
            </li>
            <li class="flex items-start gap-3 text-on-primary/80 text-sm">
              <span class="text-accent-green mt-0.5">&#10003;</span>
              Ajustes a automatizaciones existentes
            </li>
            <li class="flex items-start gap-3 text-on-primary/80 text-sm">
              <span class="text-accent-green mt-0.5">&#10003;</span>
              1 nueva oportunidad de mejora por mes
            </li>
            <li class="flex items-start gap-3 text-on-primary/80 text-sm">
              <span class="text-accent-green mt-0.5">&#10003;</span>
              Soporte prioritario por WhatsApp
            </li>
          </ul>
          <a
            href="https://wa.me/56964285737?text=Hola%2C%20me%20interesa%20el%20plan%20de%20Mantenimiento%20Mensual"
            target="_blank"
            rel="noopener"
            class="block text-center border border-on-primary/50 text-on-primary text-sm font-semibold px-6 py-3 rounded-md hover:bg-on-primary/10 transition-all"
          >
            Más información
          </a>
        </div>
      </ScrollReveal>

    </div>

    <ScrollReveal delay="300">
      <p class="text-center text-on-primary/40 text-xs mt-10">
        Precios en USD · Pagos en pesos chilenos disponibles al tipo de cambio vigente · Sin compromiso, te cotizamos en el chat.
      </p>
    </ScrollReveal>
  </div>
</section>
